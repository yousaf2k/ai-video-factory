# ==========================================
# LLM PROVIDER SELECTION
# ==========================================
# Options: gemini, openai, zhipu, qwen, kimi, ollama, lmstudio
LLM_PROVIDER=zhipu

# ==========================================
# GEMINI API CONFIGURATION
# ==========================================
# Get your API key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# OPENAI (CHATGPT) CONFIGURATION
# ==========================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ==========================================
# ZHIPU (Z.AI) CONFIGURATION
# ==========================================
# API endpoint: https://api.z.ai/api/coding/paas/v4
# Get your API key from: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# Model to use
ZHIPU_MODEL=glm-4.7

# Disable SSL verification (useful if you get SSL certificate errors)
# WARNING: This is less secure! Only use if you trust your network.
# Options: true, false
ZHIPU_DISABLE_SSL_VERIFY=false

# ==========================================
# QWEN (ALIBABA CLOUD) CONFIGURATION
# ==========================================
# Get your API key from Alibaba Cloud
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-max

# ==========================================
# KIMI (MOONSHOT AI) CONFIGURATION
# ==========================================
# Get your API key from Moonshot AI
KIMI_API_KEY=your_kimi_api_key_here
KIMI_MODEL=kimi-labs

# ==========================================
# OLLAMA CONFIGURATION (Local LLM)
# ==========================================
# Ollama server URL
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# ==========================================
# LM STUDIO CONFIGURATION (Local LLM)
# ==========================================
# LM Studio server URL
LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_MODEL=lmstudio-community/qwen2

# ==========================================
# SYSTEM PATHS CONFIGURATION
# ==========================================
# Global output directory (default: output)
# OUTPUT_DIR="output"

# ==========================================
# COMFYUI CONFIGURATION
# ==========================================
# ComfyUI server URL (default: http://127.0.0.1:8188)
# COMFY_URL=http://127.0.0.1:8188

# ComfyUI output directory (where ComfyUI saves generated videos/images)
# Leave as empty string "" to auto-detect from ComfyUI API
# Example: C:/ComfyUI_Portable/ComfyUI/output
# COMFY_OUTPUT_DIR=C:/ComfyUI_Portable/ComfyUI/output

# ==========================================
# IMAGE GENERATION CONFIGURATION
# ==========================================
# Image generation mode: "gemini" or "comfyui"
# IMAGE_GENERATION_MODE=comfyui

# Active image workflow to use (options: flux, flux2, sdxl, hidream, qwen, default)
# IMAGE_WORKFLOW=flux2

# Number of images to generate per shot (with different seeds)
# IMAGES_PER_SHOT=1

# Image aspect ratio (options: "1:1", "16:9", "9:16", "4:3", "3:4")
# IMAGE_ASPECT_RATIO=16:9

# Image resolution (options: "512", "1024", "1280", "2048")
# IMAGE_RESOLUTION=2048

# ==========================================
# VIDEO GENERATION CONFIGURATION
# ==========================================
# Default video length per shot (in seconds)
# DEFAULT_SHOT_LENGTH=5

# Maximum number of shots to generate (for testing). 0 = no limit
# DEFAULT_MAX_SHOTS=0

# Default number of shots to generate per scene (when no max_shots specified)
# DEFAULT_SHOTS_PER_SCENE=12

# Video framerate (fps)
# VIDEO_FPS=16

# Video aspect ratio (options: "1:1", "16:9", "9:16", "4:3", "3:4")
# VIDEO_ASPECT_RATIO=16:9

# Video resolution (options: "512", "720", "1024", "1080", "1280", "2048")
# VIDEO_RESOLUTION=1280

# Target total video length (in seconds). e.g., 600
# TARGET_VIDEO_LENGTH=600

# ==========================================
# AGENT & WORKFLOW CONFIGURATION
# ==========================================
# Step progression mode: "true" for auto, "false" for manual
# AUTO_STEP_MODE=true

# Agents to use for each step
# STORY_AGENT=default
# IMAGE_AGENT=default
# VIDEO_AGENT=default
# NARRATION_AGENT=default

# Whether to generate narration for videos (true/false)
# GENERATE_NARRATION=false

# TTS method: "comfyui", "local", or "elevenlabs"
# TTS_METHOD=local
